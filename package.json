{
  "name": "skill-library",
  "private": true,
  "version": "1.0.0",
  "description": "Enterprise Agent Skills registry for Cursor and compatible agents",
  "type": "module",
  "scripts": {
    "validate": "node scripts/validate-skills.mjs",
    "catalog": "node scripts/generate-catalog.mjs",
    "build:web": "npm run catalog --workspace @skill-library/web",
    "dev:web": "npm run dev --workspace @skill-library/web",
    "build": "npm run validate && npm run catalog && npm run build --workspace @skill-library/web"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "yaml": "^2.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
